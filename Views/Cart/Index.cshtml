@model List<TheWalkco.Models.CartItem>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Shopping Cart";

    decimal totalPrice = 0;
    if (Model != null)
    {
        totalPrice = Model.Sum(item => item.UnitPrice * item.Quantity);
    }
}

<style>
    .cart-table img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 8px;
    }

    .quantity-input {
        width: 60px;
        text-align: center;
        border-radius: 5px;
        border: 1px solid #ccc;
        padding: 0.3rem;
    }

    .btn-remove {
        color: #dc3545;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.2rem;
    }

        .btn-remove:hover {
            color: #a71d2a;
        }

    .cart-summary {
        font-size: 1.2rem;
        font-weight: 600;
        text-align: right;
        margin-top: 1.5rem;
    }

    .checkout-btn {
        background-color: #000;
        color: #fff;
        font-weight: 600;
        padding: 0.7rem 2rem;
        border: none;
        border-radius: 30px;
        cursor: pointer;
        transition: background-color 0.3s ease;
        float: right;
        margin-top: 1rem;
    }

        .checkout-btn:hover {
            background-color: #444;
        }
</style>

<div class="container my-5">
    <h2 class="mb-4">Your Shopping Cart</h2>

    @if (Model == null || Model.Count == 0)
    {
        <p>Your cart is empty. <a href="/Product">Start shopping</a> now!</p>
    }
    else
    {
        <table class="table cart-table align-middle">
            <thead>
                <tr>
                    <th>Product</th>
                    <th></th>
                    <th>Price</th>
                    <th style="width:120px;">Quantity</th>
                    <th>Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                        
                        var imagePath = !string.IsNullOrEmpty(item.ImageUrl)
                        ? Url.Content(item.ImageUrl)
                        : Url.Content("~/images/placeholder.png");


               
                    <tr>
                        
                        <td>
                            <img src="@imagePath"
                                 alt="@item.ProductName"
                                 style="width:100px; height:auto;" />
                        </td>                       
                        <td>@item.ProductName <br /> <small>Size: @item.Size</small></td>
                        <td>$@item.UnitPrice</td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="size" value="@item.Size" />
                                <input type="number" name="quantity" min="1" value="@item.Quantity" class="quantity-input" onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td>$@(item.UnitPrice * item.Quantity)</td>
                        <td>
                            <form asp-action="Remove" method="post" class="d-inline">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="size" value="@item.Size" />
                                <button type="submit" class="btn-remove" title="Remove item">&times;</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="cart-summary">
            Total: $@totalPrice
        </div>

        <a href="/Checkout/Index" class="checkout-btn">Proceed to Checkout</a>
    }
</div>
