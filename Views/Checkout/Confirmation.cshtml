@model TheWalkco.Models.OrderConfirmation

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Order Confirmation";
}

<style>
    .confirmation {
        text-align: center;
        margin: 6rem auto;
        max-width: 600px;
        padding: 0 1rem;
    }

        .confirmation h2 {
            font-weight: 700;
            margin-bottom: 20px;
            font-size: 2.5rem;
        }

        .confirmation p {
            font-size: 1.2rem;
            color: #555;
            line-height: 1.5;
        }

    .btn-home {
        margin-top: 30px;
        background-color: #000;
        color: #fff;
        padding: 0.7rem 2.5rem;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        transition: background-color 0.3s ease;
    }

        .btn-home:hover {
            background-color: #444;
            color: white;
            text-decoration: none;
        }

    .order-details {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px;
        margin: 20px 0;
        text-align: left;
    }
</style>

<div class="container confirmation" role="main">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
    </div>

    <h2>Thank You for Your Order!</h2>
    <p>Your order has been successfully placed. We will process it shortly and send you a confirmation email.</p>

    <div class="order-details">
        <h4 class="mb-3">Order Details</h4>

        <div class="row mb-2">
            <div class="col-6">
                <strong>Order Number:</strong>
            </div>
            <div class="col-6">
                #WC2024-@Model.OrderId.ToString("D5")  @* Formats order id with leading zeros *@
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-6">
                <strong>Order Date:</strong>
            </div>
            <div class="col-6">
                @Model.OrderDate.ToString("MMMM dd, yyyy")
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-6">
                <strong>Total Amount:</strong>
            </div>
            <div class="col-6">
                $@Model.TotalAmount.ToString("0.00")
            </div>
        </div>

        <div class="row">
            <div class="col-6">
                <strong>Shipping Address:</strong>
            </div>
            <div class="col-6">
                @Html.Raw(Model.ShippingAddress.Replace("\n", "<br />"))
                @* Replaces new lines with <br> for formatting *@
            </div>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="btn-home">Continue Shopping</a>
</div>
