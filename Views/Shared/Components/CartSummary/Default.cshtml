@model TheWalkco.ViewComponents.CartSummaryViewModel

<div class="cart-summary">
    <a href="/Cart/Index" class="text-decoration-none">
        <div class="card border-0 shadow-sm" style="border-radius: 10px; overflow: hidden;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="position-relative me-3">
                            <div class="bg-primary bg-opacity-10 p-2 rounded-circle">
                                <i class="fas fa-shopping-bag text-primary"></i>
                            </div>
                            @if (Model.ItemCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger"
                                      style="padding: 0.25em 0.4em; font-size: 0.7rem;">
                                    @Model.ItemCount
                                </span>
                            }
                        </div>
                        <div>
                            <div class="text-muted" style="font-size: 0.8rem;">TOTAL</div>
                            <div class="h5 mb-0 fw-bold text-dark">@Model.TotalPrice.ToString("C")</div>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right text-muted"></i>
                </div>
            </div>
        </div>
    </a>
</div>