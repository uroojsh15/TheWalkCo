@model IEnumerable<TheWalkco.Models.Product>

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var product in Model)
        {
            var imagePath = product.Category?.StartsWith("men") == true
            ? Url.Content("~/images/menshoes/" + product.ImageUrl)
            : Url.Content("~/images/womenshoes/" + product.ImageUrl);

            <div class="col-6 col-md-4 col-lg-3">
                <div class="card shadow-sm h-100">

                    <a asp-controller="Product"
                       asp-action="Details"
                       asp-route-id="@product.Id"
                       class="text-decoration-none text-dark">

                        <img src="@imagePath" class="card-img-top" alt="@product.Name" />

                        <div class="card-body text-center d-flex flex-column">
                            <h6>@product.Name</h6>
                            <p class="text-muted mt-auto">$@product.Price</p>
                        </div>
                    </a>

                    <div class="card-footer bg-white border-0">
                        <button class="btn btn-dark btn-sm w-100"
                                onclick="addToCart('@product.Id')">
                            Add to Cart
                        </button>
                    </div>

                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center">
            <p class="text-muted mt-4">No products found.</p>
        </div>
    }
</div>
