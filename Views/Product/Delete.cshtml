@model TheWalkco.Models.Product

@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
}

<h1 class="h4 mb-3">Delete Product</h1>

<div class="alert alert-warning d-flex align-items-center" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <div>
        Are you sure you want to delete this product? This action cannot be undone.
    </div>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-md-3 text-center">
                <img src="@(!string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "https://via.placeholder.com/200x200")"
                     class="img-fluid rounded" alt="Product image" />
            </div>
            <div class="col-md-9">
                <h5 class="mb-1">@Model.Name</h5>
                <p class="text-muted mb-2">Category: @Model.Category</p>
                <p class="mb-0"><strong>Price:</strong> $@Model.Price</p>
                <p class="mb-0"><strong>Available Sizes:</strong> @Model.Sizes</p>
                <p class="mb-0"><strong>Stock:</strong> @Model.Stock</p>
            </div>
        </div>
    </div>
</div>

<form asp-controller="Product" asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="d-flex justify-content-end">
        <a asp-controller="Product" asp-action="AdminIndex" class="btn btn-outline-secondary me-2">Cancel</a>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash3 me-1"></i> Confirm Delete
        </button>
    </div>
</form>
